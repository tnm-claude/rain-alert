{% extends "base.html" %}

{% block title %}Rain Alert - Home{% endblock %}
{% block window_title %}Rain Alert - Home{% endblock %}

{% block menu %}
<div class="menu-bar">
    <div class="menu-item" id="menu-file">
        File
        <div class="menu-dropdown" id="menu-file-dropdown">
            <div class="menu-dropdown-item" onclick="showAddLocationDialog(); closeMenus();">Add New Location</div>
            <div class="menu-dropdown-item" onclick="showSettingsDialog(); closeMenus();">Settings</div>
        </div>
    </div>
    <div class="menu-item" id="menu-view">
        View
        <div class="menu-dropdown" id="menu-view-dropdown">
            <div class="menu-dropdown-item" onclick="window.location.href='/map'; closeMenus();">Full Screen Map</div>
        </div>
    </div>
    <div class="menu-item" id="menu-help">
        Help
        <div class="menu-dropdown" id="menu-help-dropdown">
            <div class="menu-dropdown-item" onclick="showInstructionsDialog(); closeMenus();">Instructions</div>
            <div class="menu-dropdown-item" onclick="showAboutDialog(); closeMenus();">About</div>
        </div>
    </div>
</div>
{% endblock %}

{% block content %}
<!-- Radar Viewer -->
<fieldset>
    <legend>Rain Radar - Last 2 Hours <small style="font-weight: normal; font-size: 11px;">(Data: <a href="https://www.rainviewer.com/" target="_blank" style="color: #00f;">RainViewer</a>)</small></legend>
    <div id="radar-viewer">
        <iframe
            src="https://www.rainviewer.com/map.html?loc={{ locations[0].latitude if locations else 31.5 }},{{ locations[0].longitude if locations else 34.8 }},10&oFa=1&oC=0&oU=0&oCS=1&oF=0&oAP=1&c=1&o=83&lm=0&layer=radar&sm=1&sn=1"
            width="100%"
            height="500"
            frameborder="0"
            style="border:0; display:block;"
            allowfullscreen>
        </iframe>
        <p style="margin-top: 8px; font-size: 12px; color: #666;">
            Use the controls inside the map to play/pause animation, adjust speed, and navigate through time.
        </p>
    </div>
</fieldset>

<fieldset>
    <legend>Active Alerts</legend>
    {% if alerts %}
        <ul class="alert-list">
            {% for alert in alerts %}
            <li class="alert-item{% if alert.is_slack_dismissed() %} alert-slack-dismissed{% endif %}">
                <div class="message">{{ alert.message }}</div>
                <button class="button button-danger" onclick="dismissAlert({{ alert.id }})">Dismiss</button>
            </li>
            {% endfor %}
        </ul>
    {% else %}
        <div class="empty-state">No active alerts</div>
    {% endif %}
</fieldset>

<fieldset class="mt-2">
    <legend>Monitored Locations</legend>
    {% if locations %}
        <ul class="location-list">
            {% for location in locations %}
            <li class="location-item">
                <div>
                    <strong>{{ location.address }}</strong><br>
                    <small style="color: #666;">{{ "%.4f"|format(location.latitude) }}, {{ "%.4f"|format(location.longitude) }}</small>
                </div>
                <div class="location-controls">
                    <button class="button-small button-main{% if location.is_main %} active{% endif %}"
                            onclick="setMainLocation({{ location.id }})"
                            title="{% if location.is_main %}Main location{% else %}Set as main location{% endif %}">
                        🏠
                    </button>
                    <button class="button-small button-danger"
                            onclick="removeLocation({{ location.id }})"
                            title="Remove location">
                        ✕
                    </button>
                </div>
            </li>
            {% endfor %}
        </ul>
    {% else %}
        <div class="empty-state">No monitored locations yet</div>
    {% endif %}
</fieldset>


<!-- Add Location Dialog -->
<div id="add-location-modal" class="modal">
    <div class="modal-dialog" style="width: 400px;">
        <div class="modal-title-bar">
            <div class="modal-title-text">Add New Location</div>
        </div>
        <div class="modal-body" style="padding: 16px;">
            <form id="add-location-form">
                <div class="form-group">
                    <label for="address">Address:</label>
                    <input type="text" id="address" name="address" placeholder="e.g., Tel Aviv, Israel" required style="width: 100%; padding: 4px; font-family: 'MS Sans Serif', sans-serif;">
                    <small style="color: #666; display: block; margin-top: 4px;">
                        Enter a city, street address, or landmark
                    </small>
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button class="button" id="add-location-submit-btn">Add Location</button>
            <button class="button" id="add-location-cancel-btn">Cancel</button>
        </div>
    </div>
</div>

<!-- Settings Dialog -->
<div id="settings-modal" class="modal">
    <div class="modal-dialog" style="width: 600px; max-height: 80vh; overflow-y: auto;">
        <div class="modal-title-bar">
            <div class="modal-title-text">Notification Settings</div>
        </div>
        <div class="modal-body" style="padding: 16px; display: block;">
            <form id="settings-form">
                <!-- Slack Settings -->
                <fieldset style="margin-bottom: 12px;">
                    <legend>
                        <label>
                            <input type="checkbox" id="slack_enabled" name="slack_enabled">
                            Slack Notifications
                        </label>
                    </legend>
                    <div class="form-group">
                        <label for="slack_webhook_url">Webhook URL:</label>
                        <input type="text" id="slack_webhook_url" name="slack_webhook_url" placeholder="https://hooks.slack.com/services/..." style="width: 100%; padding: 4px; font-family: inherit;">
                        <small style="color: #666; display: block; margin-top: 4px;">
                            Get webhook URL from Slack: Workspace Settings → Apps → Incoming Webhooks
                        </small>
                    </div>
                </fieldset>

                <!-- Telegram Settings -->
                <fieldset style="margin-bottom: 12px;">
                    <legend>
                        <label>
                            <input type="checkbox" id="telegram_enabled" name="telegram_enabled">
                            Telegram Notifications
                        </label>
                    </legend>
                    <div class="form-group">
                        <label for="telegram_bot_token">Bot Token:</label>
                        <input type="text" id="telegram_bot_token" name="telegram_bot_token" placeholder="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11" style="width: 100%; padding: 4px; font-family: inherit;">
                    </div>
                    <div class="form-group">
                        <label for="telegram_chat_id">Chat ID:</label>
                        <input type="text" id="telegram_chat_id" name="telegram_chat_id" placeholder="123456789" style="width: 100%; padding: 4px; font-family: inherit;">
                        <small style="color: #666; display: block; margin-top: 4px;">
                            Create bot with @BotFather, get chat ID from @userinfobot
                        </small>
                    </div>
                </fieldset>

                <!-- Email Settings -->
                <fieldset style="margin-bottom: 12px;">
                    <legend>
                        <label>
                            <input type="checkbox" id="email_enabled" name="email_enabled">
                            Email Notifications
                        </label>
                    </legend>
                    <div class="form-group">
                        <label for="email_address">Recipient Email:</label>
                        <input type="email" id="email_address" name="email_address" placeholder="your@email.com" style="width: 100%; padding: 4px; font-family: inherit;">
                    </div>
                    <div class="form-group">
                        <label for="email_smtp_server">SMTP Server:</label>
                        <input type="text" id="email_smtp_server" name="email_smtp_server" placeholder="smtp.gmail.com" style="width: 100%; padding: 4px; font-family: inherit;">
                    </div>
                    <div class="form-group">
                        <label for="email_smtp_port">SMTP Port:</label>
                        <input type="number" id="email_smtp_port" name="email_smtp_port" value="587" style="width: 100%; padding: 4px; font-family: inherit;">
                    </div>
                    <div class="form-group">
                        <label for="email_smtp_user">SMTP Username:</label>
                        <input type="text" id="email_smtp_user" name="email_smtp_user" placeholder="your@email.com" style="width: 100%; padding: 4px; font-family: inherit;">
                    </div>
                    <div class="form-group">
                        <label for="email_smtp_password">SMTP Password:</label>
                        <input type="password" id="email_smtp_password" name="email_smtp_password" placeholder="App password" style="width: 100%; padding: 4px; font-family: inherit;">
                        <small style="color: #666; display: block; margin-top: 4px;">
                            Gmail: Use App Password from Google Account settings
                        </small>
                    </div>
                </fieldset>
            </form>
        </div>
        <div class="modal-footer">
            <button class="button" id="settings-test-btn">Test Notifications</button>
            <button class="button" id="settings-submit-btn">Save Settings</button>
            <button class="button" id="settings-cancel-btn">Cancel</button>
        </div>
    </div>
</div>

<!-- Instructions Dialog -->
<div id="instructions-modal" class="modal">
    <div class="modal-dialog" style="width: 500px;">
        <div class="modal-title-bar">
            <div class="modal-title-text">Instructions</div>
        </div>
        <div class="modal-body" style="padding: 16px; display: block; text-align: left;">
            <h3 style="margin: 0 0 12px 0;">How to Use Rain Alert</h3>

            <p style="margin-bottom: 12px;"><strong>Adding Locations:</strong></p>
            <ul style="margin: 0 0 12px 20px;">
                <li>Click "File" → "Add New Location"</li>
                <li>Enter any address, city, or landmark</li>
                <li>The system will geocode it automatically</li>
            </ul>

            <p style="margin-bottom: 12px;"><strong>Configuring Notifications:</strong></p>
            <ul style="margin: 0 0 12px 20px;">
                <li>Click "File" → "Settings"</li>
                <li>Enable Slack, Telegram, or Email</li>
                <li>Enter your webhook/token details</li>
                <li>Click "Test Notifications" to verify</li>
            </ul>

            <p style="margin-bottom: 12px;"><strong>Understanding Alerts:</strong></p>
            <ul style="margin: 0 0 12px 20px;">
                <li>Red alerts = Active rain detected</li>
                <li>Blue alerts = Snoozed via Slack (30 min)</li>
                <li>System checks every 10 minutes</li>
                <li>One alert max per location</li>
            </ul>

            <p style="margin-bottom: 12px;"><strong>Radar Map:</strong></p>
            <ul style="margin: 0 20px;">
                <li>Shows last 2 hours of rain data</li>
                <li>Use Play/Pause to animate</li>
                <li>Zoom and pan the map freely</li>
                <li>Data from RainViewer API</li>
            </ul>
        </div>
        <div class="modal-footer">
            <button class="button" id="instructions-close-btn">OK</button>
        </div>
    </div>
</div>

<!-- About Dialog -->
<div id="about-modal" class="modal">
    <div class="modal-dialog" style="width: 400px;">
        <div class="modal-title-bar">
            <div class="modal-title-text">About Rain Alert</div>
        </div>
        <div class="modal-body" style="padding: 16px; display: block; text-align: center;">
            <div style="font-size: 48px; margin-bottom: 12px;">🌧️</div>
            <h2 style="margin: 0 0 8px 0;">Rain Alert</h2>
            <p style="color: #666; margin: 0 0 16px 0;">Version 1.1</p>

            <p style="margin: 0 0 12px 0; text-align: left;">
                <strong>Rain Alert</strong> monitors locations worldwide using real-time radar data and sends immediate notifications when rain is detected.
            </p>

            <p style="margin: 0 0 12px 0; text-align: left;">
                <strong>Features:</strong>
            </p>
            <ul style="margin: 0 0 16px 20px; text-align: left;">
                <li>Global rain detection</li>
                <li>Multi-channel notifications</li>
                <li>Interactive radar map</li>
                <li>Windows 98 UI theme</li>
            </ul>

            <p style="margin: 0 0 8px 0; font-size: 12px; color: #666;">
                Data powered by <a href="https://www.rainviewer.com/" target="_blank" style="color: #00f;">RainViewer</a>
            </p>
            <p style="margin: 0; font-size: 12px; color: #666;">
                © 2026 Rain Alert
            </p>
        </div>
        <div class="modal-footer">
            <button class="button" id="about-close-btn">OK</button>
        </div>
    </div>
</div>

<!-- Alert Modal Dialog -->
<div id="modal" class="modal">
    <div class="modal-dialog">
        <div class="modal-title-bar">
            <div class="modal-title-text" id="modal-title">Rain Alert</div>
        </div>
        <div class="modal-body">
            <div class="modal-icon" id="modal-icon">⚠️</div>
            <div class="modal-message" id="modal-message">Message</div>
        </div>
        <div class="modal-footer">
            <button class="button" id="modal-btn-ok">OK</button>
            <button class="button" id="modal-btn-cancel" style="display: none;">Cancel</button>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
// No Leaflet radar JavaScript needed - using embedded RainViewer iframe

// Custom Windows 98 Modal
function initMap() {
    // Find main location or default to Israel
    let mainLat = 31.5;
    let mainLon = 34.8;
    let mainZoom = 7;

    {% for location in locations %}
    {% if location.is_main %}
    mainLat = {{ location.latitude }};
    mainLon = {{ location.longitude }};
    mainZoom = 15;  // Max zoom for main location
    {% endif %}
    {% endfor %}

    // Initialize map centered on main location
    map = L.map('radar-map', {
        center: [mainLat, mainLon],
        zoom: mainZoom,
        minZoom: 1,
        maxZoom: 18
    });

    // Add CartoDB Voyager base layer
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '© OpenStreetMap contributors © CARTO',
        maxZoom: 19,
        subdomains: 'abcd',
        zIndex: 1
    }).addTo(map);

    // Create a custom pane for radar with specific z-index
    map.createPane('radarPane');
    map.getPane('radarPane').style.zIndex = 450;  // Between tile pane (400) and marker pane (600)

    // Add markers for monitored locations
    {% for location in locations %}
    const marker{{ loop.index }} = L.marker([{{ location.latitude }}, {{ location.longitude }}])
        .bindPopup('<b>{{ location.address|e }}</b>{% if location.is_main %} (Main){% endif %}')
        .addTo(map);
    locationMarkers.push(marker{{ loop.index }});
    {% endfor %}
}

// Load radar data from RainViewer API
async function loadRadarFrames() {
    try {
        const response = await fetch('https://api.rainviewer.com/public/weather-maps.json');
        const data = await response.json();

        let allFrames = data.radar.past || [];
        const host = data.host;

        console.log(`[Radar] API returned ${allFrames.length} total frames`);

        if (allFrames.length === 0) {
            document.getElementById('radar-loading').textContent = 'No radar data available';
            return;
        }

        // RainViewer API only provides ~2 hours of past data
        // Use ALL available frames for now
        radarFrames = allFrames;

        console.log(`[Radar] Using all ${radarFrames.length} available frames`);
        console.log(`[Radar] Time range: ${new Date(radarFrames[0].time * 1000).toLocaleString()} to ${new Date(radarFrames[radarFrames.length-1].time * 1000).toLocaleString()}`);

        document.getElementById('radar-loading').style.display = 'none';

        const sliderEl = document.getElementById('radar-slider');
        sliderEl.max = radarFrames.length - 1;

        currentIndex = radarFrames.length - 1; // Start with latest
        displayRadarFrame(currentIndex, host);

    } catch (error) {
        console.error('Error loading radar data:', error);
        document.getElementById('radar-loading').textContent = 'Failed to load radar';
    }
}

function displayRadarFrame(index, host) {
    if (radarFrames.length === 0) return;

    const frame = radarFrames[index];
    const path = frame.path;
    const timestamp = new Date(frame.time * 1000);

    console.log('[Radar] displayRadarFrame called - host:', host, 'path:', path);

    // Validation
    if (!host || !path) {
        console.error('[Radar] Missing host or path!', {host, path, frame});
        return;
    }

    // Remove old radar layer
    if (radarLayer) {
        map.removeLayer(radarLayer);
        radarLayer = null;
    }

    // Create tile layer URL
    const tileUrl = `${host}${path}/256/{z}/{x}/{y}/2/1_0.png`;
    console.log('[Radar] Tile URL pattern:', tileUrl);

    // Create custom GridLayer that always uses zoom 8 tiles
    const RadarLayer = L.GridLayer.extend({
        createTile: function(coords) {
            const tile = document.createElement('img');

            // Always use zoom 8 coordinates
            const zoom8 = 8;
            const scale = Math.pow(2, coords.z - zoom8);
            const x8 = Math.floor(coords.x / scale);
            const y8 = Math.floor(coords.y / scale);

            tile.src = `${host}${path}/256/${zoom8}/${x8}/${y8}/2/1_0.png`;
            tile.style.width = '256px';
            tile.style.height = '256px';
            tile.style.opacity = '0.6';

            tile.onerror = function() {
                console.error('[Radar] Tile error:', tile.src);
            };

            tile.onload = function() {
                console.log('[Radar] Tile loaded:', tile.src);
            };

            return tile;
        }
    });

    radarLayer = new RadarLayer({
        pane: 'radarPane',
        opacity: 0.6
    });

    radarLayer.addTo(map);
    console.log('[Radar] Radar layer added, current zoom:', map.getZoom());

    // Update UI with date and time
    const timestampEl = document.getElementById('radar-timestamp');
    const sliderEl = document.getElementById('radar-slider');
    const indexEl = document.getElementById('radar-index');

    // Calculate hours ago
    const hoursAgo = Math.round((Date.now() - frame.time * 1000) / (1000 * 60 * 60));

    timestampEl.textContent = timestamp.toLocaleString('en-IL', {
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    }) + ` (${hoursAgo}h ago)`;

    sliderEl.value = index;
    indexEl.textContent = `${index + 1}/${radarFrames.length}`;
}

function playRadar() {
    if (radarFrames.length === 0) return;

    // Get host from API
    fetch('https://api.rainviewer.com/public/weather-maps.json')
        .then(r => r.json())
        .then(data => {
            const host = data.host;
            playInterval = setInterval(() => {
                currentIndex = (currentIndex + 1) % radarFrames.length;
                displayRadarFrame(currentIndex, host);
            }, playSpeed);
        });
}

function stopRadar() {
    if (playInterval) {
        clearInterval(playInterval);
        playInterval = null;
    }
}

function togglePlayPause() {
    const btn = document.getElementById('radar-play-pause');

    if (isPlaying) {
        stopRadar();
        btn.textContent = '▶ Play';
        isPlaying = false;
    } else {
        playRadar();
        btn.textContent = '⏸ Pause';
        isPlaying = true;
    }
}

// Event listeners
document.getElementById('radar-play-pause').addEventListener('click', togglePlayPause);

document.getElementById('radar-prev').addEventListener('click', () => {
    if (radarFrames.length === 0) return;
    stopRadar();
    isPlaying = false;
    document.getElementById('radar-play-pause').textContent = '▶ Play';
    currentIndex = (currentIndex - 1 + radarFrames.length) % radarFrames.length;

    fetch('https://api.rainviewer.com/public/weather-maps.json')
        .then(r => r.json())
        .then(data => displayRadarFrame(currentIndex, data.host));
});

document.getElementById('radar-next').addEventListener('click', () => {
    if (radarFrames.length === 0) return;
    stopRadar();
    isPlaying = false;
    document.getElementById('radar-play-pause').textContent = '▶ Play';
    currentIndex = (currentIndex + 1) % radarFrames.length;

    fetch('https://api.rainviewer.com/public/weather-maps.json')
        .then(r => r.json())
        .then(data => displayRadarFrame(currentIndex, data.host));
});

document.getElementById('radar-speed').addEventListener('change', (e) => {
    playSpeed = parseInt(e.target.value);
    if (isPlaying) {
        stopRadar();
        playRadar();
    }
});

document.getElementById('radar-slider').addEventListener('input', (e) => {
    stopRadar();
    isPlaying = false;
    document.getElementById('radar-play-pause').textContent = '▶ Play';
    currentIndex = parseInt(e.target.value);

    fetch('https://api.rainviewer.com/public/weather-maps.json')
        .then(r => r.json())
        .then(data => displayRadarFrame(currentIndex, data.host));
});

// Initialize on page load
window.addEventListener('load', () => {
    initMap();
    loadRadarFrames();
});

// Reload radar data every 10 minutes
setInterval(loadRadarFrames, 10 * 60 * 1000);

// Custom Windows 98 Modal
function showModal(title, message, icon, showCancel, callback) {
    const modal = document.getElementById('modal');
    const modalTitle = document.getElementById('modal-title');
    const modalIcon = document.getElementById('modal-icon');
    const modalMessage = document.getElementById('modal-message');
    const btnOk = document.getElementById('modal-btn-ok');
    const btnCancel = document.getElementById('modal-btn-cancel');

    modalTitle.textContent = title;
    modalMessage.textContent = message;
    modalIcon.textContent = icon;
    btnCancel.style.display = showCancel ? 'block' : 'none';

    modal.classList.add('show');

    const cleanup = () => {
        modal.classList.remove('show');
        btnOk.onclick = null;
        btnCancel.onclick = null;
    };

    btnOk.onclick = () => {
        cleanup();
        if (callback) callback(true);
    };

    btnCancel.onclick = () => {
        cleanup();
        if (callback) callback(false);
    };
}

function dismissAlert(alertId) {
    fetch(`/api/alerts/${alertId}/dismiss`, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'}
    })
    .then(response => {
        if (response.ok) {
            location.reload();
        }
    })
    .catch(error => console.error('Error:', error));
}

function removeLocation(locationId) {
    showModal('Rain Alert', 'Remove this location?', '❓', true, (confirmed) => {
        if (confirmed) {
            fetch(`/api/locations/${locationId}`, {
                method: 'DELETE',
                headers: {'Content-Type': 'application/json'}
            })
            .then(response => {
                if (response.ok) {
                    location.reload();
                }
            })
            .catch(error => console.error('Error:', error));
        }
    });
}

function setMainLocation(locationId) {
    fetch(`/api/locations/${locationId}/set-main`, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'}
    })
    .then(response => {
        if (response.ok) {
            location.reload();
        }
    })
    .catch(error => console.error('Error:', error));
}

// Add Location Dialog Functions
function showAddLocationDialog() {
    const modal = document.getElementById('add-location-modal');
    const addressInput = document.getElementById('address');

    // Reset form
    addressInput.value = '';

    // Show modal
    modal.classList.add('show');

    // Focus on input
    setTimeout(() => addressInput.focus(), 100);
}

function closeAddLocationDialog() {
    const modal = document.getElementById('add-location-modal');
    modal.classList.remove('show');
}

async function submitAddLocation() {
    const addressInput = document.getElementById('address');
    const submitBtn = document.getElementById('add-location-submit-btn');
    const address = addressInput.value.trim();

    if (!address) {
        showModal('Error', 'Please enter an address', '❌');
        return;
    }

    // Disable button
    submitBtn.disabled = true;
    submitBtn.textContent = 'Adding...';

    try {
        const response = await fetch('/api/locations', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ address: address })
        });

        const data = await response.json();

        if (response.ok) {
            closeAddLocationDialog();
            showModal('Success', `Location added: ${data.address}`, '✓', false, () => {
                location.reload();
            });
        } else {
            showModal('Error', data.error || 'Failed to add location', '❌');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Add Location';
        }
    } catch (error) {
        showModal('Error', 'Network error. Please try again.', '❌');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Add Location';
    }
}

// Add event listeners for add location dialog
document.getElementById('add-location-submit-btn').addEventListener('click', submitAddLocation);
document.getElementById('add-location-cancel-btn').addEventListener('click', closeAddLocationDialog);
document.getElementById('add-location-form').addEventListener('submit', (e) => {
    e.preventDefault();
    submitAddLocation();
});

// Menu handling
let anyMenuOpen = false;

function closeMenus() {
    document.querySelectorAll('.menu-dropdown').forEach(dropdown => {
        dropdown.classList.remove('show');
    });
    document.querySelectorAll('.menu-item').forEach(item => {
        item.classList.remove('active');
    });
    anyMenuOpen = false;
}

function openMenu(menuId, dropdownId) {
    closeMenus();
    document.getElementById(dropdownId).classList.add('show');
    document.getElementById(menuId).classList.add('active');
    anyMenuOpen = true;
}

// File menu
document.getElementById('menu-file').addEventListener('click', function(e) {
    e.stopPropagation();
    const dropdown = document.getElementById('menu-file-dropdown');
    const isShown = dropdown.classList.contains('show');

    if (isShown) {
        closeMenus();
    } else {
        openMenu('menu-file', 'menu-file-dropdown');
    }
});

document.getElementById('menu-file').addEventListener('mouseenter', function() {
    if (anyMenuOpen) {
        openMenu('menu-file', 'menu-file-dropdown');
    }
});

// View menu
document.getElementById('menu-view').addEventListener('click', function(e) {
    e.stopPropagation();
    const dropdown = document.getElementById('menu-view-dropdown');
    const isShown = dropdown.classList.contains('show');

    if (isShown) {
        closeMenus();
    } else {
        openMenu('menu-view', 'menu-view-dropdown');
    }
});

document.getElementById('menu-view').addEventListener('mouseenter', function() {
    if (anyMenuOpen) {
        openMenu('menu-view', 'menu-view-dropdown');
    }
});

// Help menu
document.getElementById('menu-help').addEventListener('click', function(e) {
    e.stopPropagation();
    const dropdown = document.getElementById('menu-help-dropdown');
    const isShown = dropdown.classList.contains('show');

    if (isShown) {
        closeMenus();
    } else {
        openMenu('menu-help', 'menu-help-dropdown');
    }
});

document.getElementById('menu-help').addEventListener('mouseenter', function() {
    if (anyMenuOpen) {
        openMenu('menu-help', 'menu-help-dropdown');
    }
});

// Close menus when clicking outside
document.addEventListener('click', closeMenus);

// Settings Dialog Functions
async function showSettingsDialog() {
    const modal = document.getElementById('settings-modal');

    // Load current settings
    try {
        const response = await fetch('/api/settings');
        const data = await response.json();

        if (response.ok) {
            const settings = data.settings;
            document.getElementById('slack_enabled').checked = settings.slack_enabled || false;
            document.getElementById('slack_webhook_url').value = settings.slack_webhook_url || '';
            document.getElementById('telegram_enabled').checked = settings.telegram_enabled || false;
            document.getElementById('telegram_bot_token').value = settings.telegram_bot_token || '';
            document.getElementById('telegram_chat_id').value = settings.telegram_chat_id || '';
            document.getElementById('email_enabled').checked = settings.email_enabled || false;
            document.getElementById('email_address').value = settings.email_address || '';
            document.getElementById('email_smtp_server').value = settings.email_smtp_server || '';
            document.getElementById('email_smtp_port').value = settings.email_smtp_port || 587;
            document.getElementById('email_smtp_user').value = settings.email_smtp_user || '';
            document.getElementById('email_smtp_password').value = settings.email_smtp_password || '';
        }
    } catch (error) {
        console.error('Error loading settings:', error);
    }

    modal.classList.add('show');
}

function closeSettingsDialog() {
    const modal = document.getElementById('settings-modal');
    modal.classList.remove('show');
}

async function saveSettings() {
    const submitBtn = document.getElementById('settings-submit-btn');

    const formData = {
        slack_enabled: document.getElementById('slack_enabled').checked,
        slack_webhook_url: document.getElementById('slack_webhook_url').value.trim(),
        telegram_enabled: document.getElementById('telegram_enabled').checked,
        telegram_bot_token: document.getElementById('telegram_bot_token').value.trim(),
        telegram_chat_id: document.getElementById('telegram_chat_id').value.trim(),
        email_enabled: document.getElementById('email_enabled').checked,
        email_address: document.getElementById('email_address').value.trim(),
        email_smtp_server: document.getElementById('email_smtp_server').value.trim(),
        email_smtp_port: parseInt(document.getElementById('email_smtp_port').value) || 587,
        email_smtp_user: document.getElementById('email_smtp_user').value.trim(),
        email_smtp_password: document.getElementById('email_smtp_password').value
    };

    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving...';

    try {
        const response = await fetch('/api/settings', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(formData)
        });

        const data = await response.json();

        if (response.ok) {
            closeSettingsDialog();
            showModal('Success', 'Settings saved successfully!', '✓');
        } else {
            showModal('Error', data.error || 'Failed to save settings', '❌');
        }
    } catch (error) {
        showModal('Error', 'Network error. Please try again.', '❌');
    } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Save Settings';
    }
}

async function testNotifications() {
    const testBtn = document.getElementById('settings-test-btn');

    testBtn.disabled = true;
    testBtn.textContent = 'Testing...';

    try {
        const response = await fetch('/api/test-notifications', {
            method: 'POST'
        });

        const data = await response.json();

        if (response.ok) {
            showModal('Success', data.message || 'Test notification sent!', '✓');
        } else {
            showModal('Error', data.error || 'Failed to send test notification', '❌');
        }
    } catch (error) {
        showModal('Error', 'Network error. Please try again.', '❌');
    } finally {
        testBtn.disabled = false;
        testBtn.textContent = 'Test Notifications';
    }
}

// Event listeners for settings dialog
document.getElementById('settings-submit-btn').addEventListener('click', saveSettings);
document.getElementById('settings-cancel-btn').addEventListener('click', closeSettingsDialog);
document.getElementById('settings-test-btn').addEventListener('click', testNotifications);

// Instructions Dialog Functions
function showInstructionsDialog() {
    const modal = document.getElementById('instructions-modal');
    modal.classList.add('show');
}

function closeInstructionsDialog() {
    const modal = document.getElementById('instructions-modal');
    modal.classList.remove('show');
}

document.getElementById('instructions-close-btn').addEventListener('click', closeInstructionsDialog);

// About Dialog Functions
function showAboutDialog() {
    const modal = document.getElementById('about-modal');
    modal.classList.add('show');
}

function closeAboutDialog() {
    const modal = document.getElementById('about-modal');
    modal.classList.remove('show');
}

document.getElementById('about-close-btn').addEventListener('click', closeAboutDialog);

// Auto-refresh alerts every 30 seconds (fetch without page reload to avoid interrupting radar)
setInterval(async () => {
    try {
        const response = await fetch('/api/alerts');
        const data = await response.json();

        // If there are new alerts, reload the page
        const currentAlerts = document.querySelectorAll('.alert-item').length;
        if (data.alerts && data.alerts.length > currentAlerts) {
            location.reload();
        }
    } catch (error) {
        console.error('Error checking alerts:', error);
    }
}, 30000);
</script>
{% endblock %}
